[user]
    name = Vihang Mehta
    email = {{ .git_email }}
    signingkey = {{ .git_signingkey }}
[github]
    user = vihangm
[color]
    ui = true
[color "branch"]
    current = yellow reverse
    local = yellow
    remote = green
[color "diff"]
    meta = yellow
    frag = magenta
    old = red
    new = green
    whitespace = red reverse
[color "status"]
    added = yellow
    changed = green
    untracked = cyan
[core]
    whitespace=fix,-indent-with-non-tab,trailing-space,cr-at-eol
[diff]
    external = difft --display=side-by-side-show-both --tab-width=2 --background=light
[merge]
    tool = gmeld
[alias]
    co = checkout
    br = branch
    rb = rebase
    st = status
    mru = branch --sort=-committerdate
[push]
    default = simple
    autoSetupRemote = true
[commit]
    gpgsign = true
[rebase]
    updateRefs = true
[pager]
    branch = false
[maintenance]
    repo = /home/gimlet
